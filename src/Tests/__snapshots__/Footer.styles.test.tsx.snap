exports[`Footer.styles > Wrapper renders a footer and matches snapshot 1`] = `
.c0 {
  position: absolute;
  left: 50%;
  bottom: 16px;
  transform: translateX(-50%);
  animation: k0 0.9s ease 0.25s both;
  z-index: 10;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  max-width: calc(100vw - 32px);
  background: var(--pf-card);
  border: 1px solid var(--pf-border-soft);
  border-radius: var(--pf-radius-pill);
  padding: 6px 14px;
  box-shadow: var(--pf-shadow-card);
  font-size: 0.8125rem;
  color: var(--pf-text-muted);
  white-space: nowrap;
}

@media (prefers-reduced-motion: reduce) {
  .c0 {
    animation: none;
  }
}

@keyframes k0 {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

<footer
  class="c0"
/>
`;
